 // 加载更多
 function loadMore() {
+    if (state.isLoadingMore) return;
+    const end = state.currentPage * CONFIG.itemsPerPage;
+    if (state.filteredData && state.filteredData.length <= end) return; // 已经加载完
+    
+    state.isLoadingMore = true;
     state.currentPage++;
     renderList();
 }
